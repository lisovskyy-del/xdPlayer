<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:xdPlayer.App.Views"
        x:Class="xdPlayer.App.MainWindow"
        Title="xdPlayer"
        Width="800" Height="500">

    <Grid RowDefinitions="*,Auto">
        <!-- тут буде плейлист -->
        <TextBlock Grid.Row="0" Text="Playlist" Margin="16"/>

        <!-- нижня панель -->
        <views:PlayerView Grid.Row="1"/>
    </Grid>

</Window>