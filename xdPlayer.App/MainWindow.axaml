<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:xdPlayer.App.Views"
        x:Class="xdPlayer.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        xmlns:vm="using:xdPlayer.App.ViewModels"
        Title="xdPlayer"
        Width="900" Height="500"
        MinWidth="700"
        MinHeight="250"
        Background="#1E1E1E">

    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="220,*">

            <views:SidebarView
                Grid.Column="0"
                DataContext="{Binding Playlist}"/>

<Grid Grid.Column="1">

    <views:LibraryView
        Name="LibraryViewControl"
        DataContext="{Binding Library}"
        IsVisible="{Binding $parent[Window].DataContext.ShowLibrary}"/>

    <views:PlaylistView
        DataContext="{Binding Playlist}"
        IsVisible="{Binding $parent[Window].DataContext.ShowPlaylist}"/>

</Grid>

        </Grid>

        <views:PlayerView
            Grid.Row="1"
            DataContext="{Binding Player}"/>
    </Grid>

</Window>