<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:xdPlayer.App.Views"
        x:Class="xdPlayer.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        xmlns:vm="using:xdPlayer.App.ViewModels"
        Title="xdPlayer"
        Width="900" Height="500"
        MinWidth="700"
        MinHeight="250"
        Background="#1E1E1E">

<Window.DataTemplates>

    <DataTemplate DataType="vm:LibraryViewModel">
        <views:LibraryView/>
    </DataTemplate>

    <DataTemplate DataType="vm:PlaylistViewModel">
        <views:PlaylistView/>
    </DataTemplate>

</Window.DataTemplates>

<Grid RowDefinitions="*,Auto">
     <Grid Grid.Row="0" ColumnDefinitions="220,*">

          <views:SidebarView
                Grid.Column="0"
                DataContext="{Binding Sidebar}"/>

<Grid Grid.Column="1">

    <ContentControl Content="{Binding CurrentPage}"/>

</Grid>

        </Grid>

        <views:PlayerView
            Grid.Row="1"
            DataContext="{Binding Player}"/>
    </Grid>

</Window>