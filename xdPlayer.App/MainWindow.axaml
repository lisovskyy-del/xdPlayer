<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:xdPlayer.App.Views"
        x:Class="xdPlayer.App.MainWindow"
        Title="xdPlayer"
        Width="900" Height="500"
        MinWidth="700"
        MinHeight="250"
        Background="#1E1E1E">

    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="220,*">

            <views:SidebarView Grid.Column="0"/>

            <Grid Grid.Column="1">
                <views:LibraryView Name="LibraryViewControl"/>
            </Grid>

        </Grid>
        <views:PlayerView Grid.Row="1"/>
    </Grid>

</Window>