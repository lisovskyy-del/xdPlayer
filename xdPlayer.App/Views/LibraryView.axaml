<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:xdPlayer.App.ViewModels"
             xmlns:entities="using:xdPlayer.Domain.Entities"
             x:Class="xdPlayer.App.Views.LibraryView"
             x:DataType="vm:LibraryViewModel">

    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="8">
            <Button Content="+ File"   Command="{Binding AddFileCommand}"/>
            <Button Content="+ Folder" Command="{Binding AddFolderCommand}"/>
            <TextBox Watermark="Search..."
                     Text="{Binding SearchQuery}"
                     Width="200"/>
        </StackPanel>

<ListBox Grid.Row="1" 
         ItemsSource="{Binding Tracks}">
    <ListBox.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </ListBox.Styles>
<ListBox.ItemTemplate>
    <DataTemplate>
        <Grid ColumnDefinitions="*,120,120,80,60"
              DoubleTapped="OnTrackDoubleTapped"
              PointerPressed="OnGridPointerPressed"
              VerticalAlignment="Stretch"
              Background="Transparent">

            <Grid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add to playlist">
                        <MenuItem.ItemsSource>
                            <Binding Path="$parent[UserControl].((vm:LibraryViewModel)DataContext).Playlists"/>
                        </MenuItem.ItemsSource>
                        <MenuItem.ItemTemplate>
                            <DataTemplate x:DataType="entities:Playlist">
                                <MenuItem Header="{Binding Name}"
                                          Click="OnAddToPlaylist"/>
                            </DataTemplate>
                        </MenuItem.ItemTemplate>
                    </MenuItem>
                </ContextMenu>
            </Grid.ContextMenu>

            <TextBlock Grid.Column="0" Text="{Binding Title}"           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="4"/>
            <TextBlock Grid.Column="1" Text="{Binding Artist}"          TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="4"/>
            <TextBlock Grid.Column="2" Text="{Binding Album}"           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="4"/>
            <TextBlock Grid.Column="3" Text="{Binding Genre}"           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="4"/>
            <TextBlock Grid.Column="4" Text="{Binding DurationSeconds}"                                  VerticalAlignment="Center" Margin="4"/>
        </Grid>
    </DataTemplate>
</ListBox.ItemTemplate>
</ListBox>

    </Grid>

</UserControl>