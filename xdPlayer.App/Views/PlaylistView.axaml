<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:xdPlayer.App.ViewModels"
             x:Class="xdPlayer.App.Views.PlaylistView"
             x:DataType="vm:PlaylistViewModel">

<Grid RowDefinitions="Auto,*"
      Margin="20">

    <!-- Header -->

<Grid Grid.Row="0"
      ColumnDefinitions="140,*"
      Margin="0,0,0,20">

    <!-- Cover -->
    <Border Width="120"
            Height="120"
            CornerRadius="8"
            Background="#333">

        <Image Source="{Binding SelectedPlaylist.CoverImagePath}"
               Stretch="UniformToFill"/>

    </Border>

    <!-- Info -->
    <StackPanel Grid.Column="1"
                Margin="20,0,0,0"
                VerticalAlignment="Bottom"
                Spacing="6">

        <TextBlock Text="Playlist"
                   Opacity="0.7"
                   FontSize="14"/>

        <TextBlock Text="{Binding SelectedPlaylist.Name}"
                   FontSize="34"
                   FontWeight="Bold"/>

        <TextBlock Text="{Binding CurrentTracks.Count, StringFormat='{}{0} tracks'}"
                   Opacity="0.7"/>

    </StackPanel>

</Grid>

    <!-- Tracks -->

<ListBox Grid.Row="1"
         ItemsSource="{Binding CurrentTracks}"
         BorderThickness="0"
         Background="Transparent">

    <ListBox.Styles>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

    </ListBox.Styles>

    <ListBox.ItemTemplate>

        <DataTemplate>

            <Border Background="#222"
                    CornerRadius="6"
                    Padding="10">

                <Grid ColumnDefinitions="40,56,*,180,70">

                    <!-- Id -->
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="{Binding Id}"
                               Opacity="0.6"/>

                    <Border Grid.Column="1"
        Width="46"
        Height="46"
        CornerRadius="4"
        Background="#444"
        ClipToBounds="True">

    <Image Source="{Binding CoverImagePath}"
           Stretch="UniformToFill"/>

</Border>

                    <!-- Track -->
                    <StackPanel Grid.Column="2"
                                Spacing="2">

                        <TextBlock Text="{Binding Title}"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding Artist}"
                                   FontSize="12"
                                   Opacity="0.65"/>

                    </StackPanel>

                    <!-- Album -->
                    <TextBlock Grid.Column="3"
                               VerticalAlignment="Center"
                               Text="{Binding Album}"
                               Opacity="0.7"/>

                    <!-- Duration -->
                    <TextBlock Grid.Column="4"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Text="{Binding DurationSeconds}"/>

                </Grid>

            </Border>

        </DataTemplate>

    </ListBox.ItemTemplate>

</ListBox>

</Grid>

</UserControl>