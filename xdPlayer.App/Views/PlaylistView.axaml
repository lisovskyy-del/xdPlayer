<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:xdPlayer.App.ViewModels"
             x:Class="xdPlayer.App.Views.PlaylistView"
             x:DataType="vm:PlaylistViewModel">

<Grid RowDefinitions="Auto,*">

    <!-- Header -->
    <Grid Grid.Row="0"
          ColumnDefinitions="140,*"
          Margin="20,20,20,20">

        <!-- Cover -->
        <Border Width="120"
                Height="120"
                CornerRadius="8"
                Background="#333"
                ClipToBounds="True">

            <Image Source="{Binding SelectedPlaylist.CoverImagePath}"
                   Stretch="UniformToFill"/>

        </Border>

        <!-- Info -->
        <StackPanel Grid.Column="1"
                    Margin="20,0,0,0"
                    VerticalAlignment="Center"
                    Spacing="6">

            <TextBlock Text="{Binding SelectedPlaylist.Name}"
                       FontSize="34"
                       FontWeight="Bold"/>

            <TextBlock Text="{Binding TracksSummary}"
                       Opacity="0.7"/>

        </StackPanel>

    </Grid>

    <!-- Tracks -->
    <Grid Grid.Row="1"
          RowDefinitions="Auto,*"
          Background="{StaticResource BackgroundBrush}">

<!-- Column headers -->
<Grid Grid.Row="0"
      ColumnDefinitions="40,*,160,70"
      Margin="20,12,20,8">

    <TextBlock Grid.Column="0"
               Text="#"
               FontSize="11"
               FontWeight="Bold"
               Opacity="0.5"/>

    <TextBlock Grid.Column="1"
               Text="TITLE"
               FontSize="11"
               FontWeight="Bold"
               Opacity="0.5"/>

    <TextBlock Grid.Column="2"
               Text="ARTIST"
               FontSize="11"
               FontWeight="Bold"
               Opacity="0.5"/>

    <TextBlock Grid.Column="3"
               Text="DURATION"
               FontSize="11"
               FontWeight="Bold"
               Opacity="0.5"
               HorizontalAlignment="Right"/>

</Grid>

        <!-- Track rows -->
        <ListBox Grid.Row="1"
                 Classes="trackList"
                 Margin="10,0,10,10"
                 ItemsSource="{Binding CurrentTracks}">

            <ListBox.ItemTemplate>

                <DataTemplate>

<Border Classes="trackRow"
        Padding="10">

    <Grid ColumnDefinitions="40,*,160,70"
          PointerPressed="OnTrackPointerPressed"
          DoubleTapped="OnTrackDoubleTapped">

        <!-- Id -->
        <TextBlock Grid.Column="0"
                   VerticalAlignment="Center"
                   Text="{Binding Id}"
                   Opacity="0.6"/>

        <!-- Title -->
        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   Text="{Binding Title}"
                   FontWeight="SemiBold"
                   TextTrimming="CharacterEllipsis"/>

        <!-- Artist -->
        <TextBlock Grid.Column="2"
                   VerticalAlignment="Center"
                   Text="{Binding Artist}"
                   Opacity="0.7"
                   TextTrimming="CharacterEllipsis"/>

        <!-- Duration -->
        <TextBlock Grid.Column="3"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"
                   Text="{Binding DurationSeconds,
                   Converter={StaticResource DurationConverter}}"/>

    </Grid>

</Border>

                </DataTemplate>

            </ListBox.ItemTemplate>

        </ListBox>

    </Grid>

</Grid>

</UserControl>