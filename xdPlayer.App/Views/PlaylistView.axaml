<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:xdPlayer.App.ViewModels"
             x:Class="xdPlayer.App.Views.PlaylistView"
             x:DataType="vm:PlaylistViewModel">

    <Grid ColumnDefinitions="200,*">

        <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto">

            <TextBlock Grid.Row="0" Text="Playlists"
                       FontWeight="Medium" Margin="8,8,8,4"/>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Playlists}"
                     SelectedItem="{Binding SelectedPlaylist}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto"
                              DoubleTapped="OnTrackDoubleTapped"
                              Background="Transparent"
                              VerticalAlignment="Stretch">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Command="{Binding $parent[UserControl].((vm:PlaylistViewModel)DataContext).DeletePlaylistCommand}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="4"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Spacing="4" Margin="8">
                <TextBox Watermark="Playlist name..."
                         Text="{Binding NewPlaylistName}"/>
                <Button Content="+ Create"
                        Command="{Binding CreatePlaylistCommand}"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>

        </Grid>

        <Grid Grid.Column="1" RowDefinitions="Auto,*">

            <TextBlock Grid.Row="0"
                       Text="{Binding SelectedPlaylist.Name}"
                       FontWeight="Medium" Margin="8,8,8,4"/>

<ListBox Grid.Row="1"
         ItemsSource="{Binding CurrentTracks}"
         DragDrop.AllowDrop="True">
    <ListBox.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </ListBox.Styles>
    <ListBox.ItemTemplate>
        <DataTemplate>
            <Grid ColumnDefinitions="*,Auto"
                  DoubleTapped="OnTrackDoubleTapped"
                  Background="Transparent"
                  VerticalAlignment="Stretch"
                  PointerPressed="OnTrackPointerPressed"
                  PointerReleased="OnTrackPointerReleased"
                  DragDrop.Drop="OnTrackDrop">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Title}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Artist}"
                               FontSize="11"
                               Opacity="0.6"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="✕"
                        Command="{Binding $parent[UserControl].((vm:PlaylistViewModel)DataContext).RemoveTrackCommand}"
                        CommandParameter="{Binding}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="4"/>
            </Grid>
        </DataTemplate>
    </ListBox.ItemTemplate>
</ListBox>

        </Grid>

    </Grid>

</UserControl>