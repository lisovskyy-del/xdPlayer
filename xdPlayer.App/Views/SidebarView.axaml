<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:xdPlayer.App.ViewModels"
             xmlns:entities="using:xdPlayer.Domain.Entities"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="xdPlayer.App.Views.SidebarView"
             x:DataType="vm:SidebarViewModel">

    <Border Background="#151515"
            Width="220">

        <Grid RowDefinitions="Auto,Auto,*,Auto"
              Margin="12">

            <!-- TOP -->
            <StackPanel Grid.Row="0" Spacing="12">

                <TextBlock Text="xdPlayer"
                           FontSize="22"
                           FontWeight="Bold"/>

<Button Content="🎵 All Tracks"
        HorizontalAlignment="Stretch"
        Command="{Binding ShowLibraryCommand}"/>

            </StackPanel>

            <!-- CREATE PLAYLIST -->
            <StackPanel Grid.Row="1"
                        Margin="0,16,0,16"
                        Spacing="8">

                <TextBox Text="{Binding NewPlaylistName}"
                         PlaceholderText="New playlist"/>

                <Button Content="Create"
                        Command="{Binding CreatePlaylistCommand}"/>

            </StackPanel>

            <!-- PLAYLISTS -->
<ListBox Grid.Row="2"
         ItemsSource="{Binding Playlists}"
         SelectedItem="{Binding SelectedPlaylist}"
         BorderThickness="0"
         Background="Transparent">

<ListBox.Styles>

    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBoxItem:pointerover">
        <Setter Property="Background" Value="#262626"/>
    </Style>

    <Style Selector="ListBoxItem:selected">
        <Setter Property="Background" Value="#323232"/>
    </Style>

</ListBox.Styles>

    <ListBox.ItemTemplate>

<DataTemplate x:DataType="entities:Playlist">

    <Grid Height="34"
          Margin="0,1">

<StackPanel Orientation="Horizontal"
            Margin="12,0"
            Spacing="8">

    <PathIcon Data="{StaticResource FolderIcon}"
              Width="16"
              Height="16"/>

    <TextBlock Text="{Binding Name}"
               VerticalAlignment="Center"/>

</StackPanel>

    </Grid>

</DataTemplate>

    </ListBox.ItemTemplate>

</ListBox>

            <!-- BOTTOM -->
            <Border Grid.Row="3"
                    Background="#222"
                    Padding="10"
                    CornerRadius="8">

                <TextBlock Text="User"
                           HorizontalAlignment="Center"/>

            </Border>

        </Grid>

    </Border>

</UserControl>