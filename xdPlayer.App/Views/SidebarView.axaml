<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:xdPlayer.App.ViewModels"
             xmlns:entities="using:xdPlayer.Domain.Entities"
             x:Class="xdPlayer.App.Views.SidebarView"
             x:DataType="vm:PlaylistViewModel">

    <Border Background="#151515"
            Width="220">

        <Grid RowDefinitions="Auto,Auto,*,Auto"
              Margin="12">

            <!-- TOP -->
            <StackPanel Grid.Row="0" Spacing="12">

                <TextBlock Text="xdPlayer"
                           FontSize="22"
                           FontWeight="Bold"/>

                <Button Content="🎵 All Tracks"
                        HorizontalAlignment="Stretch"/>

            </StackPanel>

            <!-- CREATE PLAYLIST -->
            <StackPanel Grid.Row="1"
                        Margin="0,16,0,16"
                        Spacing="8">

                <TextBox Text="{Binding NewPlaylistName}"
                         Watermark="New playlist"/>

                <Button Content="Create"
                        Command="{Binding CreatePlaylistCommand}"/>

            </StackPanel>

            <!-- PLAYLISTS -->
<ListBox Grid.Row="2"
         ItemsSource="{Binding Playlists}"
         SelectedItem="{Binding SelectedPlaylist}"
         BorderThickness="0"
         Background="Transparent">

    <ListBox.Styles>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

    </ListBox.Styles>

    <ListBox.ItemTemplate>

        <DataTemplate x:DataType="entities:Playlist">

            <Border Background="#222"
                    Padding="8"
                    CornerRadius="6">

                <TextBlock Text="{Binding Name}"/>

            </Border>

        </DataTemplate>

    </ListBox.ItemTemplate>

</ListBox>

            <!-- BOTTOM -->
            <Border Grid.Row="3"
                    Background="#222"
                    Padding="10"
                    CornerRadius="8">

                <TextBlock Text="User"
                           HorizontalAlignment="Center"/>

            </Border>

        </Grid>

    </Border>

</UserControl>