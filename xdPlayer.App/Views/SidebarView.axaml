<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:xdPlayer.App.ViewModels"
             xmlns:entities="using:xdPlayer.Domain.Entities"
             x:Class="xdPlayer.App.Views.SidebarView"
             x:DataType="vm:SidebarViewModel">

    <Border Background="{StaticResource SidebarBackgroundBrush}"
            Width="240">

        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
              Margin="12,16,12,12">

            <!-- LOGO -->
            <TextBlock Grid.Row="0"
                       Text="xdPlayer"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       Margin="6,0,0,16"/>

            <!-- ALL TRACKS -->
<!-- ALL TRACKS -->
<Button Grid.Row="1"
        Classes="sidebarRow"
        Classes.selected="{Binding IsLibrarySelected}"
        Command="{Binding ShowLibraryCommand}"
        HorizontalAlignment="Stretch"
        Margin="0,0,0,16">
    <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="🎵" FontSize="14" VerticalAlignment="Center"/>
        <TextBlock Text="All Tracks"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}"/>
    </StackPanel>
</Button>

            <!-- PLAYLISTS SECTION HEADER -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,Auto"
                  Margin="6,4,6,8">

                <TextBlock Grid.Column="0"
                           Text="PLAYLISTS"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextSubtleBrush}"
                           VerticalAlignment="Center"/>

<!-- add button -->
<Button Grid.Column="1"
        Classes="iconButton"
        Command="{Binding ToggleAddPlaylistCommand}"
        ToolTip.Tip="New playlist">
    <TextBlock Text="＋" FontSize="14" Foreground="{StaticResource TextMutedBrush}"/>
</Button>

            </Grid>

            <!-- PLAYLISTS LIST -->
            <Grid Grid.Row="3"
                  RowDefinitions="Auto,*">

                <!-- Inline "new playlist" input -->
                <Border Grid.Row="0"
                        IsVisible="{Binding IsAddingPlaylist}"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6"
                        Margin="0,0,0,6"
                        Padding="8,6">

                    <StackPanel Spacing="6">

                        <TextBox Text="{Binding NewPlaylistName}"
                                 Watermark="Playlist name"
                                 Name="NewPlaylistTextBox"/>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="6"
                                    HorizontalAlignment="Right">

                            <Button Content="Cancel"
                                    Command="{Binding CancelAddPlaylistCommand}"
                                    Background="Transparent"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    BorderThickness="0"/>

                            <Button Content="Create"
                                    Command="{Binding ConfirmAddPlaylistCommand}"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="White"
                                    CornerRadius="4"
                                    Padding="10,4"/>

                        </StackPanel>

                    </StackPanel>

                </Border>

                <ListBox Grid.Row="1"
                         Classes="playlistList"
                         ItemsSource="{Binding Playlists}"
                         SelectedItem="{Binding SelectedPlaylist}">

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="entities:Playlist">

                            <Grid Height="34">
                                <StackPanel Orientation="Horizontal"
                                            Margin="10,0"
                                            Spacing="10"
                                            VerticalAlignment="Center">

<!-- playlist item icon -->
<TextBlock Text="🎧" FontSize="12" VerticalAlignment="Center"/>

                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextBrush}"
                                               TextTrimming="CharacterEllipsis"/>

                                </StackPanel>
                            </Grid>

                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

            </Grid>

<!-- user footer -->
<Border Grid.Row="4" Classes="userFooter" Margin="0,12,0,0" Padding="8">
    <StackPanel Orientation="Horizontal" Spacing="10">
        <Border Width="28" Height="28" CornerRadius="14"
                Background="{StaticResource SurfaceBrush}"/>
        <TextBlock Text="User" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
    </StackPanel>
</Border>

        </Grid>

    </Border>

</UserControl>