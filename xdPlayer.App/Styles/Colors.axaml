<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BackgroundBrush" Color="#121212"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#1DB954"/>
    <SolidColorBrush x:Key="TextBrush" Color="White"/>

    <!-- Sidebar-specific -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#0A0A0A"/>
<SolidColorBrush x:Key="SidebarHoverBrush" Color="#14FFFFFF"/>
<SolidColorBrush x:Key="SidebarSelectedBrush" Color="#1FFFFFFF"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#8A8A8A"/>
    <SolidColorBrush x:Key="TextSubtleBrush" Color="#606060"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#242424"/>

</ResourceDictionary>